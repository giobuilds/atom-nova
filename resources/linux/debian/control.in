Package: <%= appFileName %>
Version: <%= version %>
Depends: git, libgcrypt20, libgtk-3-0 (>= 3.9.10), libnotify4, libnss3 (>= 2:3.22), libglib2.0-bin | kde-cli-tools | kde-runtime, xdg-utils, libasound2 (>= 1.0.16) | libasound2t64, libgbm1, libx11-xcb1, libxcb-dri3-0, libxss1, libxtst6, libxkbfile1, libcurl3 | libcurl4
Recommends: policykit-1 | pkexec, libsecret-1-0, gnome-keyring
Suggests: lsb-release
Section: devel
Priority: optional
Architecture: <%= arch %>
Installed-Size: <%= installedSize %>
Maintainer: Chevron maintainers <https://github.com/builtbygio/chevron>
Description: <%= description %>
 Chevron is a modernised fork of Atom — a hackable text editor for the 21st century.
